# Omega Agent — API Key
# After running `omega provider`, the API key is saved here automatically.
# You can also set it manually:
#   OMEGA_API_KEY=sk-...
#
# Supported providers: openai, anthropic, google, mistral, xai, cerebras,
# groq, kimi, minimax, openrouter, azure, bedrock, huggingface, local
OMEGA_API_KEY=
